# Copy this to .env and fill in your real secrets.
# Never commit .env to Git.

# LLM Provider (required for therapy + crisis LLM detection)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model paths — these defaults work for local dev and Docker.
# On Render/Docker they are set automatically in render.yaml / Dockerfile.
VOSK_MODEL_PATH=models/vosk-model
PIPER_BIN=/opt/piper/piper
PIPER_MODEL=models/piper/en_US-lessac-medium.onnx
VOSK_SAMPLE_RATE=16000

# Optional: LangSmith tracing
# LANGCHAIN_API_KEY=...
# LANGCHAIN_PROJECT=CogniCove
